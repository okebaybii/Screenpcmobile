<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>PCToMobile</AssemblyName>
    <RootNamespace>PCToMobile</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
    <Version>1.1.0</Version>
    <Authors>PC to Mobile</Authors>
    <Product>PC to Mobile</Product>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="Assets\AppIcon.ico"/>
  </ItemGroup>
  <ItemGroup Condition="Exists('artifacts\scrcpy-v4\scrcpy-win64-v4.0')">
    <Content Include="artifacts\scrcpy-v4\scrcpy-win64-v4.0\**\*">
      <Link>tools\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="QRCoder" Version="1.8.0"/>
  </ItemGroup>
</Project>
