<Window x:Class="PCToMobile.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:PCToMobile.Models"
        Title="PC to Mobile"
        Width="1120"
        Height="730"
        MinWidth="940"
        MinHeight="620"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">
    <Window.Resources>
        <DataTemplate DataType="{x:Type models:AndroidDevice}">
            <Grid Margin="2,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="34"
                        Height="46"
                        VerticalAlignment="Center"
                        Background="#E5F2F4"
                        BorderBrush="#A8CDD4"
                        BorderThickness="1"
                        CornerRadius="5">
                    <TextBlock FontFamily="Segoe Fluent Icons"
                               FontSize="18"
                               Foreground="{StaticResource PrimaryBrush}"
                               Text="&#xE8EA;"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <StackPanel Grid.Column="1"
                            Margin="8,0,6,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayName}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Serial}"
                               Margin="0,3,0,0"
                               FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Border Grid.Column="2"
                        Padding="7,3"
                        Background="#EDF3F5"
                        CornerRadius="4"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConnectionLabel}"
                               FontSize="10"
                               Foreground="#40535C"/>
                </Border>
            </Grid>
        </DataTemplate>

        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="itemBorder"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#F1F5F6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="itemBorder" Property="Background" Value="#E4F1F3"/>
                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="#8ABDC7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="22,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36"
                            Height="36"
                            Background="{StaticResource PrimaryBrush}"
                            CornerRadius="6">
                        <TextBlock Text="&#xE8EA;"
                                   FontFamily="Segoe Fluent Icons"
                                   FontSize="19"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="PC to Mobile"
                                   FontSize="17"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Trung tâm điều khiển Android"
                                   FontSize="11"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Padding="10,5"
                            Margin="0,0,10,0"
                            Background="#F1F4F5"
                            CornerRadius="5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ToolStatusDot"
                                     Width="7"
                                     Height="7"
                                     Margin="0,0,7,0"
                                     VerticalAlignment="Center"
                                     Fill="{StaticResource WarningBrush}"/>
                            <TextBlock x:Name="ToolStatusText"
                                       Text="Đang kiểm tra công cụ"
                                       FontSize="11"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button Width="38"
                            Padding="0"
                            ToolTip="Làm mới thiết bị"
                            Click="RefreshButton_Click">
                        <TextBlock FontFamily="Segoe Fluent Icons"
                                   FontSize="16"
                                   Text="&#xE72C;"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Thiết bị"
                                   Style="{StaticResource SectionTitle}"/>
                        <Border Grid.Column="1"
                                Height="22"
                                MinWidth="24"
                                Padding="7,2"
                                Background="#E5F2F4"
                                CornerRadius="4">
                            <TextBlock x:Name="DeviceCountText"
                                       Text="0"
                                       FontSize="11"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <Grid Grid.Row="1">
                        <ListBox x:Name="DeviceList"
                                 ItemsSource="{Binding Devices}"
                                 SelectionChanged="DeviceList_SelectionChanged"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                        <StackPanel x:Name="EmptyDeviceState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#xE7F8;"
                                       FontFamily="Segoe Fluent Icons"
                                       FontSize="34"
                                       Foreground="#9AA6AD"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Chưa tìm thấy thiết bị"
                                       Margin="0,12,0,0"
                                       Foreground="{StaticResource MutedBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="76"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="SelectedDeviceName"
                                           Text="Chọn một thiết bị"
                                           FontSize="18"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="SelectedDeviceDetail"
                                           Text="USB hoặc Wi-Fi"
                                           Margin="0,5,0,0"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button x:Name="StopButton"
                                        Width="42"
                                        Margin="0,0,8,0"
                                        Padding="0"
                                        ToolTip="Dừng phiên điều khiển"
                                        IsEnabled="False"
                                        Click="StopButton_Click">
                                    <TextBlock Text="&#xE71A;"
                                               FontFamily="Segoe Fluent Icons"
                                               FontSize="15"/>
                                </Button>
                                <Button x:Name="MirrorButton"
                                        MinWidth="170"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="False"
                                        Click="MirrorButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE768;"
                                                   FontFamily="Segoe Fluent Icons"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="Mở màn hình"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TabControl Grid.Row="1"
                                Margin="16"
                                Background="Transparent"
                                BorderThickness="0">
                        <TabItem Header="Điều khiển">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid Margin="4,18,4,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Chất lượng hình ảnh"
                                                   Style="{StaticResource SectionTitle}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Độ phân giải tối đa"
                                                           Style="{StaticResource LabelText}"/>
                                                <ComboBox x:Name="MaxSizeCombo" SelectedIndex="2">
                                                    <ComboBoxItem Content="1024 px" Tag="1024"/>
                                                    <ComboBoxItem Content="1280 px" Tag="1280"/>
                                                    <ComboBoxItem Content="1920 px" Tag="1920"/>
                                                    <ComboBoxItem Content="2560 px" Tag="2560"/>
                                                </ComboBox>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Tốc độ khung hình"
                                                           Style="{StaticResource LabelText}"/>
                                                <ComboBox x:Name="FpsCombo" SelectedIndex="2">
                                                    <ComboBoxItem Content="30 FPS" Tag="30"/>
                                                    <ComboBoxItem Content="45 FPS" Tag="45"/>
                                                    <ComboBoxItem Content="60 FPS" Tag="60"/>
                                                    <ComboBoxItem Content="120 FPS" Tag="120"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="Bitrate"
                                                   Margin="0,18,0,5"
                                                   Style="{StaticResource LabelText}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="44"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="BitRateSlider"
                                                    Minimum="2"
                                                    Maximum="24"
                                                    Value="8"
                                                    TickFrequency="2"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="BitRateSlider_ValueChanged"/>
                                            <TextBlock x:Name="BitRateText"
                                                       Grid.Column="1"
                                                       Text="8M"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Tùy chọn phiên"
                                                   Style="{StaticResource SectionTitle}"/>
                                        <CheckBox x:Name="AudioCheck"
                                                  Content="Truyền âm thanh"
                                                  IsChecked="True"/>
                                        <CheckBox x:Name="StayAwakeCheck"
                                                  Content="Giữ thiết bị luôn thức"
                                                  IsChecked="True"/>
                                        <CheckBox x:Name="ScreenOffCheck"
                                                  Content="Tắt màn hình điện thoại"/>
                                        <CheckBox x:Name="RecordCheck"
                                                  Content="Ghi lại phiên điều khiển"/>

                                        <Border Margin="0,18,0,0"
                                                Padding="12"
                                                Background="#F4F7F8"
                                                CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="&#xE7BA;"
                                                           FontFamily="Segoe Fluent Icons"
                                                           FontSize="16"
                                                           Foreground="{StaticResource PrimaryBrush}"
                                                           Margin="0,1,10,0"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Chuột và bàn phím"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="Điều khiển chuột và bàn phím đã bật"
                                                               Margin="0,4,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Wi-Fi">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="4,18,4,8">
                                    <TextBlock Text="Ghép đôi bằng QR"
                                               Style="{StaticResource SectionTitle}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="232"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="232"
                                                Height="232"
                                                Background="White"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="5">
                                            <Grid>
                                                <Image x:Name="QrPairingImage"
                                                       Width="216"
                                                       Height="216"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                <StackPanel x:Name="QrPlaceholder"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE8B9;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               FontSize="34"
                                                               Foreground="#9AA6AD"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Chưa tạo mã QR"
                                                               Margin="0,10,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource MutedBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="QrPairingStatusText"
                                                       Text="Sẵn sàng tạo phiên ghép đôi"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock x:Name="QrPairingDetailText"
                                                       Text="ADB Wireless Debugging"
                                                       Margin="0,7,0,18"
                                                       FontSize="11"
                                                       Foreground="{StaticResource MutedBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Button x:Name="StartQrPairingButton"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="StartQrPairingButton_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE71B;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="Tạo mã QR"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="CancelQrPairingButton"
                                                    Margin="0,8,0,0"
                                                    IsEnabled="False"
                                                    Click="CancelQrPairingButton_Click"
                                                    Content="Hủy chờ quét"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Height="1"
                                            Margin="0,20"
                                            Background="{StaticResource BorderBrush}"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Kết nối trực tiếp"
                                                       Style="{StaticResource SectionTitle}"/>
                                            <TextBlock Text="IP và cổng kết nối"
                                                       Style="{StaticResource LabelText}"/>
                                            <TextBox x:Name="ConnectEndpointText"
                                                     Text="192.168.1.100:5555"/>
                                            <Button Margin="0,12,0,0"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Click="ConnectButton_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE71B;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="Kết nối"/>
                                                </StackPanel>
                                            </Button>
                                            <Button x:Name="DisconnectButton"
                                                    Margin="0,8,0,0"
                                                    IsEnabled="False"
                                                    Click="DisconnectButton_Click"
                                                    Content="Ngắt thiết bị đã chọn"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Ghép đôi bằng mã"
                                                       Style="{StaticResource SectionTitle}"/>
                                            <TextBlock Text="IP và cổng ghép đôi"
                                                       Style="{StaticResource LabelText}"/>
                                            <TextBox x:Name="PairEndpointText"
                                                     Text="192.168.1.100:37099"/>
                                            <TextBlock Text="Mã ghép đôi"
                                                       Margin="0,12,0,5"
                                                       Style="{StaticResource LabelText}"/>
                                            <TextBox x:Name="PairCodeText"
                                                     MaxLength="12"/>
                                            <Button Margin="0,12,0,0"
                                                    Click="PairButton_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8D7;"
                                                               FontFamily="Segoe Fluent Icons"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="Ghép đôi"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Nhật ký">
                            <Grid Margin="4,14,4,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hoạt động gần đây"
                                               Style="{StaticResource SectionTitle}"/>
                                    <Button Grid.Column="1"
                                            Padding="10,4"
                                            MinHeight="28"
                                            Margin="0,0,0,8"
                                            Click="ClearLogButton_Click"
                                            Content="Xóa"/>
                                </Grid>
                                <TextBox x:Name="LogText"
                                         Grid.Row="1"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Background="#F7F9FA"/>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#EEF2F4"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse x:Name="StatusDot"
                         Width="7"
                         Height="7"
                         Fill="{StaticResource MutedBrush}"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText"
                           Grid.Column="1"
                           Text="Sẵn sàng"
                           Margin="7,0,0,0"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="v1.1"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
